{
  "description": "Passive local capture for the Codex Observer spike.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$PWD/scripts/record-codex-event.ts\" >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$PWD/scripts/record-codex-event.ts\" >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$PWD/scripts/record-codex-event.ts\" >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$PWD/scripts/record-codex-event.ts\" >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$PWD/scripts/record-codex-event.ts\" >/dev/null 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
